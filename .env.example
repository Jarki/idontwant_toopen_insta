OUTPUT_DIR='output'             # (OPTIONAL) Directory where videos will be downloaded
BOT_TOKEN=''                    # Telegram bot token
MAX_FILES=100                   # (OPTIONAL) Maximum number of files to keep in the output directory
TELEGRAM_MEDIA_WRITE_TIMEOUT=120 # (OPTIONAL) Upload timeout in seconds for large videos
TELEGRAM_READ_TIMEOUT=30         # (OPTIONAL) Telegram API response timeout in seconds
JUDGMENTAL_CHANCE=0.01          # (OPTIONAL) Probability (0.0–1.0) of a judgmental GIF response
                                # instead of downloading. 0=never, 0.01=1%, 0.05=5%, etc.

# PostgreSQL — required for runtime and schema migrations
POSTGRES_DB='reels'                          # PostgreSQL database name
POSTGRES_USER='db_owner'                     # PostgreSQL bootstrap/owner user
POSTGRES_PASSWORD='change_me_bootstrap'      # PostgreSQL bootstrap/owner password

# Migration role (DDL-capable, schema owner)
DB_MIGRATION_USER='db_migration'
DB_MIGRATION_PASSWORD='change_me_migration'
DB_MIGRATION_URL='postgresql+psycopg://db_migration:change_me_migration@postgres:5432/reels'

# Application role (DML-only)
DB_APP_USER='db_app'
DB_APP_PASSWORD='change_me_app'
DATABASE_URL='postgresql+psycopg://db_app:change_me_app@postgres:5432/reels'
