OUTPUT_DIR='output'             # (OPTIONAL) Directory where videos will be downloaded
BOT_TOKEN=''                    # Telegram bot token
MAX_FILES=100                   # (OPTIONAL) Maximum number of files to keep in the output directory
TELEGRAM_MEDIA_WRITE_TIMEOUT=120 # (OPTIONAL) Upload timeout in seconds for large videos
TELEGRAM_READ_TIMEOUT=30         # (OPTIONAL) Telegram API response timeout in seconds
JUDGMENTAL_CHANCE=0.01          # (OPTIONAL) Probability (0.0–1.0) of a judgmental GIF response
                                # instead of downloading. 0=never, 0.01=1%, 0.05=5%, etc.
